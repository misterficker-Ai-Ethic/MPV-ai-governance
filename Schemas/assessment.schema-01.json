{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/assessment.schema.json",
  "title": "AI Governance Assessment",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "company_name": {
      "type": "string",
      "minLength": 1
    },
    "use_case_name": {
      "type": "string",
      "minLength": 1
    },
    "department": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "ai_system_name": {
      "type": "string",
      "minLength": 1
    },
    "data_source": {
      "type": "string",
      "minLength": 1
    },
    "uses_personal_data": {
      "type": "boolean"
    },
    "human_review": {
      "type": "boolean"
    },
    "decision_impact": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "recommended_measures": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "required": [
    "company_name",
    "use_case_name",
    "purpose",
    "ai_system_name",
    "uses_personal_data",
    "human_review",
    "risk_level"
  ]
}
